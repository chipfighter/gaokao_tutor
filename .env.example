# LLM settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# RAG settings
TAVILY_API_KEY=your_tavily_api_key_here
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Optional (sensible defaults)
CHROMA_PERSIST_DIR=chroma_store/
EMBEDDING_MODEL=BAAI/bge-m3
DEEPSEEK_MODEL=deepseek-chat

# Fallback LLM (used when primary API times out or returns 5xx)
# Defaults to primary DEEPSEEK_* config for transient-error retries.
# Override to point at a local Ollama or different cloud provider.
# FALLBACK_MODEL=deepseek-chat
# FALLBACK_API_KEY=your_fallback_key_here
# FALLBACK_BASE_URL=http://localhost:11434/v1

# PostgreSQL settings (used by langgraph-checkpoint-postgres via psycopg)
DB_URI=postgresql://postgres:your_password@localhost:5432/gaokao_tutor

# OpenTelemetry settings
OTEL_SERVICE_NAME=gaokao-tutor
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_ENABLED=true
OTEL_SQLITE_FALLBACK_PATH=logs/traces.db